{
  "manifest_version": 3,
  "name": "ArchiMemo Подложки",
  "version": "1.0.1",
  "description": "Записва изпратени подложки (.dwg) в досието на проекта",
  "background": {
    "scripts": ["background.js"]
  },
  "permissions": [
    "compose",
    "messagesRead",
    "storage"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "archmemo-podlozhki@pirindesign.com",
      "strict_min_version": "128.0"
    }
  }
}
