{
  "manifest_version": 3,
  "name": "ArchiMemo Подложки",
  "version": "1.0.2",
  "description": "Записва изпратени подложки (.dwg) в досието на проекта",
  "background": {
    "scripts": ["background.js"]
  },
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  },
  "permissions": [
    "compose",
    "messagesRead",
    "storage"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "archmemo-podlozhki@pirindesign.com",
      "strict_min_version": "128.0"
    }
  }
}
